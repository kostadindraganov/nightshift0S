{
  "$meta": {
    "name": "Nightshift Design Tokens",
    "description": "ClickHouse-style design system: near-pure black canvas with electric yellow accent"
  },
  "color": {
    "primary": "#faff69",
    "primary-active": "#e6eb52",
    "primary-disabled": "#3a3a1f",
    "ink": "#ffffff",
    "body": "#cccccc",
    "body-strong": "#e6e6e6",
    "muted": "#888888",
    "muted-soft": "#5a5a5a",
    "hairline": "#2a2a2a",
    "hairline-strong": "#3a3a3a",
    "canvas": "#0a0a0a",
    "surface-soft": "#121212",
    "surface-card": "#1a1a1a",
    "surface-elevated": "#242424",
    "on-primary": "#0a0a0a",
    "on-dark": "#ffffff",
    "accent-emerald": "#22c55e",
    "accent-rose": "#ef4444",
    "accent-blue": "#3b82f6",
    "success": "#22c55e",
    "warning": "#f59e0b",
    "error": "#ef4444"
  },
  "spacing": {
    "xxs": "4px",
    "xs": "8px",
    "sm": "12px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px",
    "xxl": "48px",
    "section": "96px"
  },
  "radius": {
    "xs": "4px",
    "sm": "6px",
    "md": "8px",
    "lg": "12px",
    "pill": "9999px",
    "full": "9999px"
  },
  "font": {
    "family": {
      "sans": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
      "mono": "'JetBrains Mono', ui-monospace, SFMono-Regular, monospace"
    },
    "scale": {
      "display-sm": {
        "fontSize": "32px",
        "fontWeight": "700",
        "lineHeight": "1.2",
        "letterSpacing": "-1px"
      },
      "title-lg": {
        "fontSize": "24px",
        "fontWeight": "700",
        "lineHeight": "1.3",
        "letterSpacing": "-0.3px"
      },
      "title-md": {
        "fontSize": "18px",
        "fontWeight": "600",
        "lineHeight": "1.4",
        "letterSpacing": "0"
      },
      "title-sm": {
        "fontSize": "16px",
        "fontWeight": "600",
        "lineHeight": "1.4",
        "letterSpacing": "0"
      },
      "body-md": {
        "fontSize": "16px",
        "fontWeight": "400",
        "lineHeight": "1.55",
        "letterSpacing": "0"
      },
      "body-sm": {
        "fontSize": "14px",
        "fontWeight": "400",
        "lineHeight": "1.55",
        "letterSpacing": "0"
      },
      "caption": {
        "fontSize": "13px",
        "fontWeight": "500",
        "lineHeight": "1.4",
        "letterSpacing": "0"
      },
      "caption-uppercase": {
        "fontSize": "12px",
        "fontWeight": "600",
        "lineHeight": "1.4",
        "letterSpacing": "1.5px"
      },
      "code": {
        "fontSize": "14px",
        "fontWeight": "400",
        "lineHeight": "1.55",
        "letterSpacing": "0"
      },
      "button": {
        "fontSize": "14px",
        "fontWeight": "600",
        "lineHeight": "1",
        "letterSpacing": "0"
      },
      "nav-link": {
        "fontSize": "14px",
        "fontWeight": "500",
        "lineHeight": "1.4",
        "letterSpacing": "0"
      },
      "stat": {
        "fontSize": "56px",
        "fontWeight": "700",
        "lineHeight": "1.0",
        "letterSpacing": "-1.5px"
      }
    }
  }
}
