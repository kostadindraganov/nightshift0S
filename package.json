{
  "name": "nightshift",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": ["vendor/sandcastle"],
  "scripts": {
    "dev": "bun run src/server/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test src/db src/events src/server src/tasks src/config src/providers src/worktree src/sandbox/ src/egress src/runs src/forge src/gate src/orchestrator src/thread src/review src/planner src/scheduler src/notify src/triggers src/experiment src/memory src/analytics src/maintenance src/verify src/preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "drizzle-orm": "^0.45.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "playwright": "^1.53.0",
    "typescript": "^6.0.3"
  }
}
